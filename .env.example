TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_STRING_SESSION=

# LLM backend: set OPENROUTER_API_KEY to use OpenRouter (free DeepSeek/Gemini),
# or OPENAI_API_KEY for OpenAI. OPENROUTER_API_KEY takes priority if both are set.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Optional for ingest; required for processor/approver.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

TG_BOT_TOKEN=

WORKSPACE_ID=
WORKSPACE_TITLE=
GROUP_CHAT_ID=
INGEST_THREAD_ID=
REVIEW_THREAD_ID=
PUBLISH_CHANNEL_ID=
SOURCE_CHATS=
GPT_PROFILE=default

PUBSUB_TOPIC=tg-raw-ingested
PUBSUB_VERIFICATION_AUDIENCE=
APPROVER_NOTIFY_URL=

BOOTSTRAP_MAX_AGE_DAYS=30

BUHGALTER911_LOGIN=
BUHGALTER911_PASSWORD=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

LOG_LEVEL=INFO
